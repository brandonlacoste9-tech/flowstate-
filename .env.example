# Contact form → Resend
# 1. Create account at https://resend.com
# 2. Add & verify domain flowstate-design.co (DNS: SPF, DKIM, optionally DMARC)
# 3. Create an API key and set it here (and in Netlify env vars)
RESEND_API_KEY=

# Inbox that receives form submissions
CONTACT_TO_EMAIL=hello@flowstate-design.co

# Must use a verified domain sender once DNS is set
# Example after domain verify:
# CONTACT_FROM_EMAIL=Flowstate Design <hello@flowstate-design.co>
# Until verified, Resend allows:
CONTACT_FROM_EMAIL=Flowstate Design <onboarding@resend.dev>
